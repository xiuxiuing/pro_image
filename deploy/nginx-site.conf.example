# 复制为 /etc/nginx/sites-available/pro-image 后：
#   sudo ln -s /etc/nginx/sites-available/pro-image /etc/nginx/sites-enabled/
# 将 server_name 改为你的域名；certbot 可自动改 SSL 段
#
# upstream 指向 gunicorn（见 pro-image.service）

upstream pro_image_app {
    server 127.0.0.1:5001;
    keepalive 2;
}

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.example.com;

    client_max_body_size 100M;

    location / {
        proxy_pass http://pro_image_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
